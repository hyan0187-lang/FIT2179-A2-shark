{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Age & Gender of Shark Attack Victims",
    "subtitle": "Males dominate across every age group",
    "fontSize": 18,
    "fontWeight": "bold",
    "subtitleFontSize": 12,
    "subtitleColor": "#888888",
    "anchor": "start"
  },
  "width": "container",
  "height": 280,
  "config": {"view": {"stroke": ""}},
  "data": {
    "values": [
      {"age_group": "0–9",   "gender": "Male",   "count": 11},
      {"age_group": "0–9",   "gender": "Female", "count": 3},
      {"age_group": "10–19", "gender": "Male",   "count": 208},
      {"age_group": "10–19", "gender": "Female", "count": 35},
      {"age_group": "20–29", "gender": "Male",   "count": 185},
      {"age_group": "20–29", "gender": "Female", "count": 17},
      {"age_group": "30–39", "gender": "Male",   "count": 125},
      {"age_group": "30–39", "gender": "Female", "count": 13},
      {"age_group": "40–49", "gender": "Male",   "count": 77},
      {"age_group": "40–49", "gender": "Female", "count": 8},
      {"age_group": "50–59", "gender": "Male",   "count": 41},
      {"age_group": "50–59", "gender": "Female", "count": 9},
      {"age_group": "60–69", "gender": "Male",   "count": 15},
      {"age_group": "60–69", "gender": "Female", "count": 7},
      {"age_group": "70–79", "gender": "Male",   "count": 6},
      {"age_group": "70–79", "gender": "Female", "count": 0},
      {"age_group": "80+",   "gender": "Male",   "count": 1},
      {"age_group": "80+",   "gender": "Female", "count": 0}
    ]
  },
  "transform": [
    {
      "calculate": "datum.gender === 'Male' ? -datum.count : datum.count",
      "as": "signed_count"
    }
  ],
  "layer": [
    {
      "mark": {"type": "bar", "cornerRadiusEnd": 3},
      "encoding": {
        "y": {
          "field": "age_group",
          "type": "ordinal",
          "sort": ["0–9","10–19","20–29","30–39","40–49","50–59","60–69","70–79","80+"],
          "axis": {
            "title": null,
            "labelFontSize": 11,
            "ticks": false,
            "domain": false
          }
        },
        "x": {
          "field": "signed_count",
          "type": "quantitative",
          "axis": {
            "title": "Number of victims",
            "titleFontSize": 11,
            "labelFontSize": 11,
            "labelExpr": "abs(datum.value)",
            "grid": true,
            "gridColor": "#eeeeee"
          }
        },
        "color": {
          "field": "gender",
          "type": "nominal",
          "scale": {
            "domain": ["Male", "Female"],
            "range": ["#FFD700", "#FF69B4"]
          },
          "legend": {
            "title": "Gender",
            "titleFontSize": 11,
            "labelFontSize": 11,
            "orient": "bottom"
          }
        },
        "tooltip": [
          {"field": "age_group", "title": "Age group"},
          {"field": "gender", "title": "Gender"},
          {"field": "count", "title": "Victims"}
        ]
      }
    },
    {
      "mark": {"type": "rule", "color": "#cccccc", "strokeWidth": 1},
      "encoding": {"x": {"datum": 0}}
    },
    {
      "data": {
        "values": [
          {"age_group": "0–9", "x": -95, "label": "◀ MALE (89%)",   "col": "#FFD700"},
          {"age_group": "0–9", "x":  10, "label": "FEMALE (11%) ▶", "col": "#FF69B4"}
        ]
      },
      "mark": {"type": "text", "align": "left", "fontSize": 10, "fontWeight": "bold"},
      "encoding": {
        "y": {
          "field": "age_group",
          "type": "ordinal",
          "sort": ["0–9","10–19","20–29","30–39","40–49","50–59","60–69","70–79","80+"]
        },
        "x": {"field": "x", "type": "quantitative"},
        "text": {"field": "label", "type": "nominal"},
        "color": {"field": "col", "type": "nominal", "scale": null, "legend": null}
      }
    },
    {
      "transform": [
        {"calculate": "datum.gender === 'Male' ? -datum.count : datum.count", "as": "signed_count"},
        {"filter": "datum.age_group === '10–19'"}
      ],
      "mark": {"type": "text", "align": "right", "dx": -4, "fontSize": 10, "fontWeight": "bold"},
      "encoding": {
        "y": {
          "field": "age_group",
          "type": "ordinal",
          "sort": ["0–9","10–19","20–29","30–39","40–49","50–59","60–69","70–79","80+"]
        },
        "x": {"field": "signed_count", "type": "quantitative"},
        "text": {"field": "count", "type": "quantitative"},
        "color": {
          "field": "gender",
          "type": "nominal",
          "scale": {"domain": ["Male","Female"], "range": ["#FFD700","#FF69B4"]},
          "legend": null
        }
      }
    }
  ]
}