{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "config": {"view": {"stroke": ""}},
  "title": {
    "text": "Shark Incident Outcomes in Australia (1791–2025)",
    "subtitle": "Total of 1,283 recorded incidents",
    "fontSize": 16,
    "fontWeight": "bold",
    "subtitleFontSize": 12,
    "subtitleColor": "#ffffff",
    "anchor": "start"
  },
  "data": {
    "values": [
      {"category": "Fatal", "count": 259},
      {"category": "Injured", "count": 776},
      {"category": "Uninjured", "count": 245}
    ]
  },
  "hconcat": [
    {
      "width": 200,
      "height": 200,
      "title": {"text": "Proportion", "fontSize": 12, "color": "#ffffff"},
      "mark": {"type": "arc", "innerRadius": 60, "outerRadius": 100},
      "encoding": {
        "theta": {"field": "count", "type": "quantitative"},
        "color": {
          "field": "category",
          "type": "nominal",
          "scale": {
            "domain": ["Fatal", "Injured", "Uninjured"],
            "range": ["#e63946", "#f59e0b", "#06b6d4"]
          },
          "legend": {
            "title": "Outcome",
            "titleFontSize": 12,
            "labelFontSize": 12,
            "orient": "bottom"
          }
        },
        "tooltip": [
          {"field": "category", "title": "Outcome"},
          {"field": "count", "title": "Count", "format": ","},
          {"calculate": "round(datum.count / 1283 * 100) + '%'", "as": "pct", "title": "Percentage"}
        ]
      }
    },
    {
      "width": 300,
      "height": 200,
      "title": {"text": "Count", "fontSize": 12, "color": "#ffffff"},
      "mark": {"type": "bar", "cornerRadiusEnd": 4},
      "encoding": {
        "x": {
          "field": "count",
          "type": "quantitative",
          "axis": {
            "title": "Number of incidents",
            "titleFontSize": 11,
            "labelFontSize": 11,
            "grid": true,
            "gridColor": "#eeeeee"
          }
        },
        "y": {
          "field": "category",
          "type": "nominal",
          "sort": ["Fatal", "Injured", "Uninjured"],
          "axis": {
            "title": null,
            "labelFontSize": 12,
            "ticks": false,
            "domain": false
          }
        },
        "color": {
          "field": "category",
          "type": "nominal",
          "scale": {
            "domain": ["Fatal", "Injured", "Uninjured"],
            "range": ["#e63946", "#f59e0b", "#06b6d4"]
          },
          "legend": null
        },
        "text": {
          "field": "count",
          "type": "quantitative",
          "format": ","
        },
        "tooltip": [
          {"field": "category", "title": "Outcome"},
          {"field": "count", "title": "Count", "format": ","},
          {"calculate": "round(datum.count / 1283 * 100) + '%'", "as": "pct", "title": "Percentage"}
        ]
      }
    }
  ]
}